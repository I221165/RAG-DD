# ============================================================
# Required secrets — copy this file to `.env` and fill in
# ============================================================

# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# MongoDB Atlas connection string (free M0 cluster works fine)
# Format: mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=rag_chatbot

# ============================================================
# Provider selection (factory keys) — change to swap backends
# ============================================================
LLM_PROVIDER=groq
EMBEDDING_PROVIDER=sentence_transformers
VECTOR_STORE=chroma
CHAT_HISTORY_STORE=mongodb

# ============================================================
# Models
# ============================================================
MODEL_NAME=llama-3.3-70b-versatile
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ============================================================
# RAG tuning
# ============================================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=4
HISTORY_TURNS=6
TEMPERATURE=0.2
MAX_TOKENS=1024

# ============================================================
# Storage paths (relative to `backend/` when running uvicorn from there)
# ============================================================
CHROMA_PATH=./chroma_db
UPLOAD_DIR=./uploads
CHROMA_COLLECTION=documents

# ============================================================
# Upload limits
# ============================================================
MAX_UPLOAD_MB=20

# ============================================================
# CORS (JSON array of allowed origins)
# ============================================================
ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
